#!/usr/bin/env bash
#
# bin/dock - Simplified commands for Docker development environment
#
# Usage:
#   bin/dock <command> [args]
#
# Commands:
#   setup          First-time setup (build images)
#   up [-d]        Start all services (use -d for background)
#   down [-v]      Stop services (use -v to remove data)
#   logs [service] View logs (optionally for a specific service)
#   run <cmd>      Run a one-off command
#   exec <cmd>     Execute command in running container
#   build          Rebuild Docker images
#   ps             List running containers
#   restart        Restart the web server
#   reset          Stop containers, remove volumes, and rebuild
#   gh <cmd>       Run GitHub CLI commands
#   help           Show this help message
#

set -e

COMPOSE_FILE="docker-compose.dev.yml"

# Show help if no command provided
show_help() {
  echo "Usage: bin/dock <command> [args]"
  echo ""
  echo "Commands:"
  echo "  setup          First-time setup (build images)"
  echo "  up [-d]        Start all services (use -d for background)"
  echo "  down [-v]      Stop services (use -v to remove data)"
  echo "  logs [service] View logs (optionally for a specific service)"
  echo "  run <cmd>      Run a one-off command"
  echo "  exec <cmd>     Execute command in running container"
  echo "  build          Rebuild Docker images"
  echo "  ps             List running containers"
  echo "  restart        Restart the web server"
  echo "  reset          Stop containers, remove volumes, and rebuild"
  echo "  gh <cmd>       Run GitHub CLI commands"
  echo "  help           Show this help message"
  echo ""
  echo "Examples:"
  echo "  bin/dock setup           # Build images"
  echo "  bin/dock up              # Start the application"
  echo "  bin/dock run yarn add X  # Add a package"
  echo "  bin/dock run node -v     # Check Node version"
  echo ""
  echo "Visit: http://localhost:3003"
}

# Handle help commands immediately (no Docker needed)
COMMAND="${1:-help}"
if [ "$COMMAND" = "help" ] || [ "$COMMAND" = "--help" ] || [ "$COMMAND" = "-h" ]; then
  show_help
  exit 0
fi

# For all other commands, check if Docker is available
if ! command -v docker &> /dev/null; then
  # Try common Docker Desktop installation path on macOS
  if [ -f "/Applications/Docker.app/Contents/Resources/bin/docker" ]; then
    export PATH="/Applications/Docker.app/Contents/Resources/bin:$PATH"
  else
    echo ""
    echo "ERROR: Docker command not found."
    echo ""
    echo "Please follow these steps:"
    echo ""
    echo "  1. Download Docker Desktop from: https://docs.docker.com/desktop/install/mac-install/"
    echo "  2. Open the downloaded .dmg file"
    echo "  3. Drag Docker to your Applications folder"
    echo "  4. Open Docker from Applications (look for the whale icon)"
    echo "  5. Wait for Docker to finish starting (whale icon stops animating)"
    echo "  6. Run this command again"
    echo ""
    exit 1
  fi
fi

# Shift past the command to get remaining args
shift || true

case "$COMMAND" in
  setup)
    echo "==> Setting up Docker development environment..."

    # Build the Docker images
    echo "==> Building Docker images (this may take a few minutes the first time)..."
    docker compose -f "$COMPOSE_FILE" build

    echo ""
    echo "========================================"
    echo "  Setup complete!"
    echo "========================================"
    echo ""
    echo "Start the application with:"
    echo "  bin/dock up"
    echo ""
    echo "Visit: http://localhost:3003"
    echo ""
    ;;
  up)
    docker compose -f "$COMPOSE_FILE" up "$@"
    ;;
  down)
    docker compose -f "$COMPOSE_FILE" down "$@"
    ;;
  logs)
    docker compose -f "$COMPOSE_FILE" logs -f "$@"
    ;;
  run)
    docker compose -f "$COMPOSE_FILE" run --rm web "$@"
    ;;
  exec)
    docker compose -f "$COMPOSE_FILE" exec web "$@"
    ;;
  build)
    docker compose -f "$COMPOSE_FILE" build "$@"
    ;;
  ps)
    docker compose -f "$COMPOSE_FILE" ps "$@"
    ;;
  restart)
    echo "==> Restarting web server..."
    docker compose -f "$COMPOSE_FILE" restart web
    echo "==> Web server restarted"
    ;;
  reset)
    echo ""
    echo "WARNING: This will delete all Docker volumes (node_modules, etc.)"
    echo ""
    read -p "Are you sure? (y/N) " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      echo "Cancelled."
      exit 0
    fi

    echo "==> Stopping containers..."
    docker compose -f "$COMPOSE_FILE" down -v

    echo "==> Rebuilding images..."
    docker compose -f "$COMPOSE_FILE" build

    echo ""
    echo "========================================"
    echo "  Reset complete!"
    echo "========================================"
    echo ""
    echo "Run 'bin/dock up' to start the application."
    echo ""
    ;;
  gh)
    docker compose -f "$COMPOSE_FILE" exec web gh "$@"
    ;;
  *)
    echo "Unknown command: $COMMAND"
    echo ""
    show_help
    exit 1
    ;;
esac
