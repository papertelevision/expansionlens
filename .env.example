# ─── Required ───────────────────────────────────────────────────────────

# Postgres connection string. In Docker dev this points to the "postgres"
# service in docker-compose.dev.yml. In production, docker-compose.prod.yml
# constructs this from POSTGRES_PASSWORD at container start.
DATABASE_URL="postgresql://expansionlens:expansionlens_dev@postgres:5432/expansionlens"

# HMAC secret for signing session cookies. Must be at least 32 characters
# and NOT a placeholder. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Stripe secret key. Use sk_test_... for development, sk_live_... for
# production. https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe webhook signing secret. Required in production — the webhook
# handler rejects all events without it. Get one from the Stripe dashboard
# under Developers > Webhooks after creating a production endpoint.
STRIPE_WEBHOOK_SECRET=

# Resend API key for magic-link and purchase confirmation emails.
# https://resend.com/api-keys
RESEND_API_KEY=

# ─── Production ─────────────────────────────────────────────────────────

# Tell Next.js we're in production mode. docker-compose.prod.yml also sets
# this; leave unset for local docker-compose.dev.yml.
# NODE_ENV=production

# Postgres password used by docker-compose.prod.yml to build DATABASE_URL
# and by scripts/backup-postgres.sh. Any strong random string.
# POSTGRES_PASSWORD=

# Sender address for transactional email. Must be a verified domain address
# in Resend. Falls back to onboarding@resend.dev (dev sandbox) if unset.
# Example: 'ExpansionLens <noreply@expansionlens.com>'
# EMAIL_FROM=

# Base URL for links generated in emails and OG tags. No trailing slash.
# NEXT_PUBLIC_BASE_URL=https://expansionlens.com

# ─── Sentry (optional, recommended for production) ─────────────────────

# Server-side DSN. Sentry is a no-op if unset.
# SENTRY_DSN=
# Client-side DSN. Can be the same project as SENTRY_DSN.
# NEXT_PUBLIC_SENTRY_DSN=
# Auth token for uploading source maps during `next build`. Only needed at
# build time. Without this, Sentry still captures errors but stack traces
# won't be symbolicated.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ─── Postgres backups (used by scripts/backup-postgres.sh on the Droplet) ─

# DigitalOcean Spaces access credentials for encrypted off-site backups.
# Create these under API > Spaces Keys in the DO dashboard.
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_BUCKET=expansionlens-backups
# DO_SPACES_REGION=nyc3
# DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ─── Optional third-party APIs ──────────────────────────────────────────

# Walk Score API key. Free tier at walkscore.com/professional/api.php
# Report will show "N/A" for walkability if not set.
WALKSCORE_API_KEY=

# Google Places API key. Free tier: 10K calls/month.
# Get one at console.cloud.google.com → APIs & Services → Credentials.
# Enable "Places API" in the API Library.
# Competitor ratings/reviews won't show if not set.
GOOGLE_PLACES_API_KEY=

# Stripe product ID (optional — falls back to inline product_data).
STRIPE_PRODUCT_ID=
