# STAGING: IP-only HTTP Caddyfile for initial droplet bring-up.
#
# This variant serves any hostname over HTTP:80 so the site can be
# reached at http://<droplet-ip>/ before DNS for expansionlens.com has
# been cut over to the droplet. Bot filtering is intentionally omitted
# so smoke-test tools (curl, wget) work without extra flags.
#
# GOING LIVE:
#   Once DNS A records for expansionlens.com and www.expansionlens.com
#   point at the droplet, swap in the real production config and
#   redeploy so Caddy can provision Let's Encrypt TLS certificates:
#
#     cp Caddyfile.production Caddyfile
#     docker compose -f docker-compose.prod.yml up -d
#
#   Caddy will pick up the new config on restart and obtain certs within
#   ~30 seconds of boot.

:80 {
	encode zstd gzip

	# Forward client IP and protocol so the app's rate limiter and
	# cookie-secure logic see the real values.
	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up Host {host}
	}

	# Cache static assets aggressively.
	@static {
		path /_next/static/* /images/* /favicon.ico
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# Log to a rotated file (mounted as a volume).
	log {
		output file /var/log/caddy/expansionlens.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}
